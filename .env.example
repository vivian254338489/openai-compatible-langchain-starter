# Copy this file to .env and fill in values for your OpenAI-compatible provider.
OPENAI_COMPATIBLE_API_KEY=replace_me_with_your_provider_key
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_COMPATIBLE_MODEL=gpt-4o-mini

